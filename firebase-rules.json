{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth !== null && $uid === auth.uid",
        ".write": "auth !== null && $uid === auth.uid"
      }
    },
    "palettes": {
      "$paletteId": {
        ".read": "data.child('privacy').val() === 'public' || (auth !== null && data.child('userId').val() === auth.uid) || (auth !== null && data.child('sharedWith').child(auth.uid).exists())",
        ".write": "(auth !== null && !data.exists()) || (auth !== null && data.child('userId').val() === auth.uid) || (auth !== null && data.child('sharedWith').child(auth.uid).exists())"
      }
    },
    "shares": {
      "$shareId": {
        ".read": true,
        ".write": "auth !== null && (!data.exists() || root.child('palettes').child(data.child('paletteId').val()).child('userId').val() === auth.uid)"
      }
    },
    "iterations": {
      "$iterationId": {
        ".read": true,
        ".write": "auth !== null && (!data.exists() || root.child('palettes').child(data.child('paletteId').val()).child('userId').val() === auth.uid || root.child('palettes').child(data.child('paletteId').val()).child('sharedWith').child(auth.uid).exists())"
      }
    }
  }
}
